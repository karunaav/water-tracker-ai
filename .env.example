# ── Groq ──────────────────────────────────────────────────────────────────────
# Get your free key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql://postgres:password@localhost:5432/water_tracker
# SQLite (local dev — used automatically if DATABASE_URL is not set)
# DATABASE_URL=sqlite:///./data/water_tracker.db

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development          # development | production
LOG_LEVEL=INFO

# ── User defaults ─────────────────────────────────────────────────────────────
DAILY_GOAL_ML=2500
REMINDER_INTERVAL_MINUTES=60

# ── Observability ─────────────────────────────────────────────────────────────
ENABLE_METRICS=true
METRICS_PORT=9090
