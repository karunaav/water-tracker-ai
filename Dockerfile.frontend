FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir streamlit==1.35.0 plotly==5.22.0 requests==2.32.3 \
    pandas==2.2.2 python-dotenv==1.0.1

COPY frontend/ ./

EXPOSE 8501

CMD ["streamlit", "run", "app.py", \
     "--server.port=8501", \
     "--server.headless=true", \
     "--server.address=0.0.0.0"]
